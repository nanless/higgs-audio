# =============================================================================
# Higgs Audio v3 — 补齐(top-up)迭代克隆流水线 配置文件
#
# 与 05_iterative_pipeline.env 的唯一区别: 源目录与统计口径。
#   - 统计"总时长"时把两个已过滤 clone 目录 (higgs_123 / omnivoice) 计入 baseline;
#   - 但选参考音频 (ref) 时只用原始 audio 目录。
#   - 只对 总时长(源 + 已过滤clone) < 半小时 的说话人继续 TTS 复刻补齐。
#   - SIM/CER 剪枝阈值与 05 完全一致 (MAX_CER=0.03, MIN_SIM=0.8 raw)。
#
# 用法:
#   bash v3_tts_clone/07_topup_pipeline.sh
#   (脚本会自动 source 本文件, 再复用 05_iterative_pipeline.sh 的核心逻辑)
# =============================================================================

REPO="/root/code/github_repos/higgs-audio"
BASE="/root/group-shared/voiceprint/data/speech/speaker_diarization/merged_datasets_20250610_vad_segments_mtfaa_enhanced_extend_kid_withclone_addlibrilight_1130"

# ---- 源目录 / 统计口径 (与 05 的核心差异) ----
# 参考音频只来自原始 audio 目录
export SOURCE_DIRS="${BASE}/audio"
# 统计总时长时额外计入这两个已过滤 clone 目录 (仅计时长, 不作为参考音频来源)
export STATS_CLONE_DIRS="${BASE}/audio_higgs_audio_v3_tts_clone_123_sim0.8_filtered ${BASE}/audio_omnivoice_clone_sim0.8_filtered"
# Step 0 生成的统计 CSV (baseline = audio + 两个已过滤 clone 目录)
export STATS_CSV="${REPO}/clone_workdir/stats_topup_v5/all_speakers.csv"

# 新的 clone 输出目录 (全新, 从 0 生成; 本轮新复刻只写这里, 不动上面两个已过滤目录)
export CLONE_ROOT="${BASE}/audio_higgs_audio_v3_tts_clone_5"
export PIPELINE_WORKDIR="${REPO}/clone_workdir/iterative_pipeline_v5"

export TEXTS_JSONL="${REPO}/higgs_audio_v3_text_generator/batch_output_v2/generated_texts_final.jsonl"

# ---- 预算 / 目标 (与 05 相同的语义) ----
# TARGET_SEC: 每说话人目标半小时。TOTAL_CLONE_HOURS: 全局克隆预算, 按 gap 加权分配。
# 经验: 生成毛量 gross ≈ gap_hours / 存活率(raw0.8 约 10%) ≈ 10 × gap_hours。
# 由 07 启动器在 Step 0 统计后自动测算并注入 (见 07_topup_pipeline.sh)；
# 若已手动设置本变量, 启动器会尊重你的值不覆盖。
# export TOTAL_CLONE_HOURS=20000
export TARGET_SEC=1800
export TOTAL_ROUNDS=10

# ---- 以下与 05_iterative_pipeline.env 完全一致 ----
export BASE_PORT=8000
export NUM_SERVERS=8               # 八卡机
export WORKERS_PER_SERVER=32
export ESTIMATE_CLONE_DURATION=10
export QUALITY_PASS_RATE=0.5
export SEED=42

export MAX_CER=0.03
export MIN_SIM=0.8                 # raw 余弦阈值 (与 05 一致)
export PRUNE_WORKERS=32
export SCAN_WORKERS=64
export SIM_WORKERS=32

export ALL_GPUS="0,1,2,3,4,5,6,7"

# ---- CER/ASR 提速 (与 05 一致) ----
export ASR_BACKEND=vllm
export ASR_VLLM_BATCH=256
export ASR_GPU_MEM_UTIL=0.9
export ASR_BATCH_SIZE=32
export ASR_AUDIO_WORKERS=16
export ASR_MAX_NEW_TOKENS=512

# ---- TTS 音频长度上限 (与 05 一致) ----
export TTS_MAX_NEW_TOKENS=1024

# ---- 续跑控制 (与 05 一致) ----
export START_ROUND=1
export START_STEP=clone
