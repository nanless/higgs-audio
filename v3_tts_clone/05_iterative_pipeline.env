# =============================================================================
# Higgs Audio v3 — 10轮迭代克隆流水线 配置文件
# =============================================================================

REPO="/root/code/github_repos/higgs-audio"
BASE="/root/group-shared/voiceprint/data/speech/speaker_diarization/merged_datasets_20250610_vad_segments_mtfaa_enhanced_extend_kid_withclone_addlibrilight_1130"

export STATS_CSV="${REPO}/clone_workdir/speaker_duration_stats_v2.csv"
export TEXTS_JSONL="${REPO}/higgs_audio_v3_text_generator/batch_output_v2/generated_texts_final.jsonl"
export SOURCE_DIRS="${BASE}/audio"
export CLONE_ROOT="${BASE}/audio_higgs_audio_v3_tts_clone_3"
export PIPELINE_WORKDIR="${REPO}/clone_workdir/iterative_pipeline"

export TOTAL_CLONE_HOURS=10000
export TOTAL_ROUNDS=10
export BASE_PORT=8000
export NUM_SERVERS=4
export WORKERS_PER_SERVER=16
export ESTIMATE_CLONE_DURATION=10
export QUALITY_PASS_RATE=0.5
export SEED=42

export MAX_CER=0.03
export MIN_SIM=0.85
export PRUNE_WORKERS=32

export ALL_GPUS="0,1,2,3"

# ---- CER/ASR 提速 ----
export ASR_BATCH_SIZE=32          # 每 GPU ASR 推理 batch (A800 80GB 空间充裕, 16→32)
export ASR_AUDIO_WORKERS=16       # 音频解码/重采样并行进程, 与 GPU 推理重叠 (0=同步)
export ASR_MAX_NEW_TOKENS=512     # ASR 解码上限 (原 256 会截断长音频; 解码遇 EOS 即停, 加大对短音频无损耗)

# ---- TTS 音频长度上限 (排查发现的过度剪枝根因) ----
# 1024 tokens ~= 40.7s @ 25fps; 长文本(>~250字)音频被从中间截断 → ASR 只听到前半 →
# CER 虚高 → 长clone被过度剪枝。31.7% 的 clone 命中该上限。
# 提高可让长文本完整发声(但每条长clone更耗算力/显存)。留 1024 保持现状, 需要时上调(如 2048/3072)。
export TTS_MAX_NEW_TOKENS=1024

# ---- 续跑控制 (默认 1 / clone = 全新完整运行) ----
# START_ROUND: 从第几轮开始; START_STEP: 起始轮从哪步开始 (clone|cer|sim|prune)
# 二者只要偏离默认 (START_ROUND>1 或 START_STEP!=clone) 就进入续跑模式:
#   跳过 ASR + 预算分配, 复用已有 allocation 基准 + 磁盘已有 clone/评估结果。
# 例:  export START_ROUND=1; export START_STEP=cer    # 第1轮从 CER 评估开始
#      export START_ROUND=3                            # 从第3轮克隆开始
export START_ROUND=1
export START_STEP=clone
