# =============================================================================
# Higgs Audio v3 — 10轮迭代克隆流水线 配置文件
# =============================================================================

REPO="/root/code/github_repos/higgs-audio"
BASE="/root/group-shared/voiceprint/data/speech/speaker_diarization/merged_datasets_20250610_vad_segments_mtfaa_enhanced_extend_kid_withclone_addlibrilight_1130"

# STATS_CSV: source-only 统计 (audio 目录, 不含以前克隆)。
#   Step 0 会自动运行 00_prepare_stats.py 生成它 (统计 SOURCE_DIRS 下所有数据集/说话人)。
#   若该文件已存在则跳过; FORCE_STATS=1 可强制重算。输出固定为 <output-dir>/all_speakers.csv。
#   STATS_OUTPUT_DIR 默认 = STATS_CSV 所在目录; STATS_SOURCE_DIRS 默认 = SOURCE_DIRS。
export STATS_CSV="${REPO}/clone_workdir/stats_source_only/all_speakers.csv"
export TEXTS_JSONL="${REPO}/higgs_audio_v3_text_generator/batch_output_v2/generated_texts_final.jsonl"
export SOURCE_DIRS="${BASE}/audio"
export CLONE_ROOT="${BASE}/audio_higgs_audio_v3_tts_clone_4"   # 全新目录, 从 0 生成
export PIPELINE_WORKDIR="${REPO}/clone_workdir/iterative_pipeline_v4"

export TOTAL_CLONE_HOURS=60000     # raw0.8 存活~10% + 目标0.5h source-only → gross≈58.5k
export TARGET_SEC=1800             # 每说话人目标时长 = 半小时
export TOTAL_ROUNDS=10
export BASE_PORT=8000
export NUM_SERVERS=8               # 八卡机
export WORKERS_PER_SERVER=32       # 每 server 客户端并发 (16→32 提高吞吐, 喂满 SGLang 连续批处理)
export ESTIMATE_CLONE_DURATION=10
export QUALITY_PASS_RATE=0.5
export SEED=42

export MAX_CER=0.03
export MIN_SIM=0.8         # raw 余弦阈值 (编码器已改 raw cos; 旧 0.85 mapped = raw 0.70)
export PRUNE_WORKERS=32
export SCAN_WORKERS=64      # 全盘扫描并行进程 (网络盘 I/O 密集 → 用大值猛猛加速)
export SIM_WORKERS=32       # SIM 评估进程数 (每卡 4 个, 8 卡=32)

export ALL_GPUS="0,1,2,3,4,5,6,7"

# ---- CER/ASR 提速 ----
export ASR_BACKEND=vllm           # vllm: 连续批处理, 高 GPU 利用率 (推荐); transformers: HF generate 多线程(GIL受限)
export ASR_VLLM_BATCH=256         # vllm 喂给引擎的批大小 (越大越能填满连续批处理)
export ASR_GPU_MEM_UTIL=0.9       # vllm gpu_memory_utilization
export ASR_BATCH_SIZE=32          # transformers 后端每 GPU batch (仅 ASR_BACKEND=transformers 时用)
export ASR_AUDIO_WORKERS=16       # 音频解码/重采样并行进程, 与 GPU 推理重叠 (0=同步)
export ASR_MAX_NEW_TOKENS=512     # ASR 解码上限 (原 256 会截断长音频; 解码遇 EOS 即停, 加大对短音频无损耗)

# ---- TTS 音频长度上限 (排查发现的过度剪枝根因) ----
# 1024 tokens ~= 40.7s @ 25fps; 长文本(>~250字)音频被从中间截断 → ASR 只听到前半 →
# CER 虚高 → 长clone被过度剪枝。31.7% 的 clone 命中该上限。
# 提高可让长文本完整发声(但每条长clone更耗算力/显存)。留 1024 保持现状, 需要时上调(如 2048/3072)。
export TTS_MAX_NEW_TOKENS=1024

# ---- 续跑控制 (默认 1 / clone = 全新完整运行) ----
# 步骤顺序/级别: clone=1 < sim=2 < cer=3 (每轮: 克隆 → SIM评估+SIM剪枝 → CER评估+CER剪枝)
# START_ROUND: 从第几轮开始; START_STEP: 起始轮从哪步开始 (clone|sim|cer)
# 二者只要偏离默认 (START_ROUND>1 或 START_STEP!=clone) 就进入续跑模式:
#   跳过 ASR + 预算分配, 复用已有 allocation 基准 + 磁盘已有 clone/评估结果。
# 例:  export START_ROUND=1; export START_STEP=sim    # 第1轮从 SIM 评估开始(克隆已完成)
#      export START_ROUND=3                            # 从第3轮克隆开始
export START_ROUND=1
export START_STEP=clone
