# Higgs Audio CER Evaluation — LLM ITN settings
# GPUs 0-1: ASR (Qwen3-ASR), GPUs 2-7: LLM ITN (Qwen3.6-27B-FP8 via vLLM)
ITN_LLM_MODEL=qwen3.6-27b
ITN_LLM_API_KEY=EMPTY
# 6 vLLM instances on GPUs 2-7, ports 8002-8007 (round-robin)
ITN_LLM_BASE_URLS=http://localhost:8002/v1,http://localhost:8003/v1,http://localhost:8004/v1,http://localhost:8005/v1,http://localhost:8006/v1,http://localhost:8007/v1
# Single endpoint fallback
ITN_LLM_BASE_URL=http://localhost:8002/v1
